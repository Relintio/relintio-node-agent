{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@auraprotector/agent",
  "version": "0.1.4",
  "description": "AuraProtector in-process agent for Node runtimes.",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auraguard-co/AuraProtector.git",
    "directory": "agents/node"
  },
  "homepage": "https://github.com/auraguard-co/AuraProtector#readme",
  "bugs": {
    "url": "https://github.com/auraguard-co/AuraProtector/issues"
