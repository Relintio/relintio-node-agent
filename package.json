{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@relintio/agent",
  "version": "0.11.4",
  "description": "RelintioAgent in-process agent for Node runtimes. Provides bot mitigation, threat detection, and adaptive content protection as Express middleware or zero-code preload.",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "Relintio",
    "url": "https://relintio.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Relintio/relintio-node-agent.git"
  },
  "homepage": "https://relintio.com/docs",
  "bugs": {
    "url": "https://github.com/Relintio/relintio-node-agent/issues"
  },
  "funding": {
    "type": "commercial",
    "url": "https://relintio.com/pricing"
  },
  "keywords": [
    "relintio-agent",
    "relintio",
    "security",
    "waf",
    "middleware",
    "bot-detection",
    "bot-mitigation",
    "express",
    "threat-protection",
    "antibot"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "express": ">=4.21.2"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "overrides": {
    "range-parser": "1.2.1"
  },
  "resolutions": {
    "range-parser": "1.2.1"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": "./src/index.js",
    "./express": "./src/express.js",
    "./preload": {
      "require": "./src/preload.cjs",
      "import": "./src/preload.js"
    }
  }
}
